# Qivro production environment example
# Copy this file to .env.production on the server and fill real values there.

NODE_ENV=production
APP_ENV=production
CONTAINER_PREFIX=qivro
COMPOSE_PROJECT_NAME=qivro-production

PUBLIC_DOMAIN=qivro.io
ADMIN_DOMAIN=admin.qivro.io
API_DOMAIN=api.qivro.io
LETSENCRYPT_EMAIL=admin@qivro.io

POSTGRES_USER=qivro
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=qivro
DATABASE_URL=postgresql://qivro:change_me_strong_password@postgres:5432/qivro

JWT_SECRET=change_me_at_least_32_chars
FRONTEND_URL=https://qivro.io
ADMIN_FRONTEND_URL=https://admin.qivro.io
CORS_ORIGINS=https://qivro.io,https://www.qivro.io,https://admin.qivro.io
AI_SERVICE_URL=http://ai:8000

NEXT_PUBLIC_API_URL=http://backend:3001/api
NEXT_PUBLIC_BROWSER_API_URL=https://api.qivro.io/api
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=

EMAIL_PROVIDER=resend
EMAIL_FROM=Qivro <no-reply@qivro.io>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=qivro/listings

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BACKUP_BUCKET=