# Qivro production environment example
# Copy this file to .env.production on the server and fill real values there.

NODE_ENV=production
PUBLIC_DOMAIN=yourdomain.com
ADMIN_DOMAIN=admin.yourdomain.com
API_DOMAIN=api.yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com

POSTGRES_USER=qivro
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=qivro
DATABASE_URL=postgresql://qivro:change_me_strong_password@postgres:5432/qivro

JWT_SECRET=change_me_at_least_32_chars
FRONTEND_URL=https://yourdomain.com
ADMIN_FRONTEND_URL=https://admin.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
AI_SERVICE_URL=http://ai:8000

NEXT_PUBLIC_API_URL=http://backend:3001/api
NEXT_PUBLIC_BROWSER_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=

EMAIL_PROVIDER=resend
EMAIL_FROM=Qivro <no-reply@yourdomain.com>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=qivro/listings

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BACKUP_BUCKET=